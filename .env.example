# Canonical URL for the deployed site (set in Vercel → Settings → Environment Variables).
# Improves Open Graph / social preview URLs; falls back to VERCEL_URL on Vercel if unset.
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Optional: Supabase (enable dashboard features)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
